@model IEnumerable<lab10.Models.Borrowing>

@{
    ViewData["Title"] = "Borrowings";
}

<h1>Borrowings</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Book</th>
            <th>Member</th>
            <th>Borrow Date</th>
            <th>Due Date</th>
            <th>Return Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Book?.Title</td>
                <td>@item.Member?.FirstName @item.Member?.LastName</td>
                <td>@item.BorrowDate.ToString("yyyy-MM-dd")</td>
                <td>@item.DueDate.ToString("yyyy-MM-dd")</td>
                <td>@(item.ReturnDate?.ToString("yyyy-MM-dd") ?? "Not returned")</td>
                <td>
                    @if (item.ReturnDate == null)
                    {
                        if (item.DueDate < DateTime.Now)
                        {
                            <span class="badge bg-danger">Overdue</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Borrowed</span>
                        }
                    }
                    else
                    {
                        <span class="badge bg-success">Returned</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    @if (item.ReturnDate == null)
                    {
                        <a asp-action="Return" asp-route-id="@item.Id" class="btn btn-sm btn-success">Return</a>
                    }
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
