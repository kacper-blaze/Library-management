@{
    ViewData["Title"] = "Logged In";
    var userEmail = Context.Session.GetString("UserEmail");
    var userRole = ViewBag.UserRole as string;
    var apiToken = ViewBag.ApiToken as string;
    var borrowings = ViewBag.Borrowings as List<lab10.Models.Borrowing>;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">Successfully Logged In!</h3>
                </div>
                <div class="card-body">
                    <p class="card-text">
                        Welcome <strong>@userEmail</strong>! You have successfully logged into the application.
                    </p>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Role:</label>
                        <span class="badge bg-primary">@userRole</span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">API Token:</label>
                        <div class="input-group">
                            <input type="text" class="form-control" value="@apiToken" readonly id="apiToken">
                            <button class="btn btn-outline-secondary" type="button" onclick="copyToken()">Copy</button>
                        </div>
                        <small class="text-muted">Use this token with your username for REST API authentication</small>
                    </div>

                    <form method="post" asp-action="Logout" asp-controller="Account" asp-antiforgery="true">
                        <button type="submit" class="btn btn-danger btn-lg w-100">
                            Logout
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @if (borrowings != null && borrowings.Any())
    {
        <div class="row justify-content-center mt-4">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">My Borrowed Books</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Book Title</th>
                                        <th>Borrow Date</th>
                                        <th>Due Date</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var borrowing in borrowings)
                                    {
                                        <tr>
                                            <td>@borrowing.Book?.Title</td>
                                            <td>@borrowing.BorrowDate.ToString("yyyy-MM-dd")</td>
                                            <td>@borrowing.DueDate.ToString("yyyy-MM-dd")</td>
                                            <td>
                                                @if (borrowing.DueDate < DateTime.Now)
                                                {
                                                    <span class="badge bg-danger">Overdue</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                            </td>
                                            <td>
                                                <a asp-controller="Borrowings" asp-action="Extend" asp-route-id="@borrowing.Id" class="btn btn-sm btn-warning">Extend</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row justify-content-center mt-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body text-center">
                        <p class="text-muted">You have no borrowed books at the moment.</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<script>
function copyToken() {
    var tokenInput = document.getElementById("apiToken");
    tokenInput.select();
    document.execCommand("copy");
    alert("API Token copied to clipboard!");
}
</script>