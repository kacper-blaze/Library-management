@model List<lab10.Models.Login>
@{
    ViewData["Title"] = "Manage Users";
}

<h1>Manage Users</h1>

<div class="mb-3">
    <a asp-action="AddUser" class="btn btn-primary">Add New User</a>
    <a asp-action="LoggedIn" class="btn btn-secondary">Back to Account</a>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">All Users</h5>
    </div>
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Username</th>
                            <th>Role</th>
                            <th>API Token</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.Id</td>
                                <td>@user.Username</td>
                                <td>
                                    @if (user.Role == "Admin")
                                    {
                                        <span class="badge bg-danger">Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">User</span>
                                    }
                                </td>
                                <td><code>@user.ApiToken</code></td>
                                <td>
                                    <!-- Add delete/edit actions here if needed -->
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No users found.</p>
        }
    </div>
</div>
